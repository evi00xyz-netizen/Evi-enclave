# =============================================================================
# ERC-8004 TEE Agent Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: Deployment Configuration
# =============================================================================
# Set these as SECRETS on Phala deployment

GITHUB_REPO=https://github.com/YOUR_USERNAME/YOUR_REPO.git
GIT_COMMIT_HASH=YOUR_PRODUCTION_COMMIT_HASH
AGENT_SALT=your-unique-production-salt-here

# =============================================================================
# Agent Configuration
# =============================================================================
# AGENT_DOMAIN: Auto-set by Phala as ${DSTACK_APP_ID}-8000.${DSTACK_GATEWAY_DOMAIN}
# For local dev: localhost:8000
AGENT_DOMAIN=localhost:8000

# Display name shown in agent card
AGENT_NAME=TEE Agent

# Trust Center widget URL (get from https://trust.phala.com)
TRUST_CENTER_URL=https://trust.phala.com/widget/app/<dstack-app-id>/<widget-id>

# =============================================================================
# Blockchain Configuration
# =============================================================================
CHAIN_NAME=eth-sepolia
CHAIN_ID=11155111
RPC_URL=https://1rpc.io/sepolia

# ERC-8004 Contract Addresses (ETH Sepolia defaults)
IDENTITY_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e
REPUTATION_REGISTRY_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713

# =============================================================================
# Subgraph Configuration (REQUIRED for agent lookup)
# =============================================================================
# Get your API key from https://thegraph.com/studio/
SUBGRAPH_API_KEY=your-graph-api-key-here

# Optional: Override the auto-constructed URL
# SUBGRAPH_URL=https://gateway.thegraph.com/api/{api-key}/subgraphs/id/6wQRC7geo9XYAhckfmfo8kbMRLeWU8KQd3XsJqFKmZLT

# =============================================================================
# Server Configuration
# =============================================================================
AGENT_HOST=0.0.0.0
AGENT_PORT=8000

# Session management
SESSION_TIMEOUT_MINUTES=60
MAX_SESSIONS=100

# Code execution timeout (seconds)
CODE_EXECUTION_TIMEOUT=30

# Auto-update code on container restart
UPDATE_CODE=false

# =============================================================================
# AI Configuration (Chat Interface)
# =============================================================================
# RedPill API for TEE-secured AI inference
REDPILL_API_KEY=sk-your-api-key-here
REDPILL_API_URL=https://api.redpill.ai

# Anthropic SDK config (uses RedPill as backend)
ANTHROPIC_AUTH_TOKEN=${REDPILL_API_KEY}
ANTHROPIC_BASE_URL=https://api.redpill.ai
ANTHROPIC_MODEL=openai/gpt-oss-120b

# AI model settings
AI_MODEL=deepseek/deepseek-chat-v3-0324
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=2000

# Available TEE-secured models:
# - phala/qwen-2.5-7b-instruct (fast, good for code)
# - deepseek/deepseek-chat-v3-0324 (strong reasoning)
# - openai/gpt-oss-120b (most capable)
# - phala/llama-3.3-70b (balanced)

# =============================================================================
# Optional: Network Proxy
# =============================================================================
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=localhost,127.0.0.1

# =============================================================================
# Development Only
# =============================================================================
# DEBUG=false
# DSTACK_SIMULATOR_ENDPOINT=http://localhost:8090

# =============================================================================
# Deployment Checklist
# =============================================================================
# 1. Set GITHUB_REPO to your repository URL
# 2. Set GIT_COMMIT_HASH to production commit
# 3. Set AGENT_SALT to unique secure value
# 4. Get SUBGRAPH_API_KEY from The Graph Studio
# 5. Get REDPILL_API_KEY from RedPill
# 6. Fund agent wallet with ~0.01 ETH for gas
