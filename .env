# 1. The Dummy Keys (Tricks the template into booting without an AI model)
AGENT_SALT=evi_secure_production_salt_998877
SUBGRAPH_API_KEY=dummy_subgraph_key_not_used
REDPILL_API_KEY=dummy_redpill_key_not_used
ANTHROPIC_AUTH_TOKEN=dummy_anthropic_key_not_used

# 2. Blockchain Configuration (Locks the enclave to the Base Network)
CHAIN_NAME=base-mainnet
CHAIN_ID=8453
RPC_URL=https://mainnet.base.org

# 3. Server Configuration (Matches your docker-compose.yml ports)
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
