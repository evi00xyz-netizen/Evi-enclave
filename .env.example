# Production Deployment Configuration (Phala CVM)
# These variables should be set as SECRETS on phala.com

# ⚠️ REQUIRED: Set as secrets on Phala deployment
GITHUB_REPO=https://github.com/YOUR_USERNAME/YOUR_REPO.git
GIT_COMMIT_HASH=YOUR_PRODUCTION_COMMIT_HASH
AGENT_SALT=your-unique-production-salt-here

# Agent Configuration (auto-populated by Phala)
# AGENT_DOMAIN will be auto-set when deploying to production: ${DSTACK_APP_ID}-8000.${DSTACK_GATEWAY_DOMAIN}
# In VibeVM set the address to your domain e.g. AGENT_DOMAIN=7f56b605ad6c5f28743a6dac6481cf272f2f610a-8000.dstack-pha-prod9.phala.network
AGENT_DOMAIN=<dstack-app-id>-8000.<dstack-gateway-domain>

# Trust Center Configuration
# URL to the Phala Network TEE attestation widget
# Go to https://trust.phala.com/app/<dstack-app-id> to create your custom widget
# Format: https://trust.phala.com/widget/app/<dstack-app-id>/<widget-id>
TRUST_CENTER_URL=https://trust.phala.com/widget/app/<dstack-app-id>/<widget-id>

# ============================================================================
# Blockchain Configuration (ETH Sepolia)
# ============================================================================
# Chain name for multi-chain config (see src/agent/chain_config.py for available chains)
CHAIN_NAME=eth-sepolia
CHAIN_ID=11155111
RPC_URL=https://1rpc.io/sepolia

# Subgraph API Key for The Graph Gateway (required for subgraph queries)
# Get your API key from https://thegraph.com/studio/
SUBGRAPH_API_KEY=your-graph-api-key-here

# Subgraph URL (optional override - usually auto-constructed from API key)
# SUBGRAPH_URL=https://gateway.thegraph.com/api/{api-key}/subgraphs/id/6wQRC7geo9XYAhckfmfo8kbMRLeWU8KQd3XsJqFKmZLT

# ============================================================================
# Contract Addresses (ETH Sepolia)
# ============================================================================
# ERC-8004 Registries
IDENTITY_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e
REPUTATION_REGISTRY_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713

# ============================================================================
# Server Configuration
# ============================================================================
AGENT_HOST=0.0.0.0
# For production deploy, set to 80. For VibeVM set to 8000
AGENT_PORT=8000

# Code Update Policy
UPDATE_CODE=false

# ============================================================================
# AI Configuration (RedPill Confidential AI)
# ============================================================================
REDPILL_API_KEY=sk-your-api-key-here
REDPILL_API_URL=https://api.redpill.ai

# AI Model Settings (for ai_generate_and_execute task type)
AI_MODEL=deepseek/deepseek-chat-v3-0324
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=2000

# Available TEE-secured models:
# - phala/qwen-2.5-7b-instruct (recommended for code generation, fast)
# - deepseek/deepseek-chat-v3-0324 (strong reasoning, good for complex logic)
# - openai/gpt-oss-120b (most capable, slower)
# - phala/llama-3.3-70b (balanced performance)
# All models run in NVIDIA H100 TEE with cryptographic attestation

# ============================================================================
# TEE Sandbox (Optional)
# ============================================================================
# Auto-configured by Phala CVM. For local VibeVM development, set manually:
# SANDBOX_URL=http://sandbox:8080

# ============================================================================
# Production Deployment Notes
# ============================================================================
# 1. Set GITHUB_REPO to your forked repository URL
# 2. Set GIT_COMMIT_HASH to your production-ready commit
# 3. Set AGENT_SALT to a unique, secure value
# 4. Ensure entrypoint.sh has correct build/deploy steps
# 5. Upload docker-compose.yml to Phala and configure CVM
# 6. Fund your agent wallet with ETH Sepolia ETH (0.001 ETH minimum)
